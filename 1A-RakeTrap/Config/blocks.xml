<?xml version="1.0" encoding="UTF-8" ?>
<configs>

	<append xpath="/blocks">
		<block name="rakeTrap">
			<property name="Class" value="RakeTrap.BlockRakeTrap, RakeTrap" />
			<property name="DisplayType" value="blockHardened" />
			<property name="CustomIcon" value="trapSpikesWoodMaster" />
			<property name="DescriptionKey" value="rakeTrapDesc" />
			<property name="Material" value="MtrapSpikesWood" />
			<property name="Shape" value="ModelEntity" />
			<property name="Model" value="#@modfolder:Resources/raketrap.unity3d?RakeTrapPrefab.prefab" />
			<property name="ModelOffset" value="0,0,0" />
			<property name="GndAlign" value="1" />
			<property name="OversizedBounds" value="(-0.5,0,-1.25),(1,1.5,2)" />
			<property name="ImposterExclude" value="true" />
			<property name="LightOpacity" value="0" />
			<property name="WaterFlow" value="permitted" />
			<property name="Place" value="TowardsPlacerInverted" />
			<property name="OnlySimpleRotations" value="true" />
			<property name="Collide" value="melee,bullet,arrow,rocket" />
			<property name="Path" value="solid" />
			<property name="IsTerrainDecoration" value="true" />
			<property name="StabilitySupport" value="false" />
			<property name="StabilityIgnore" value="true" />
			<property name="ShowModelOnFall" value="false" />
			<property name="MaxDamage" value="100" />
			<property name="EconomicValue" value="18" />
			<property name="EconomicBundleSize" value="10" />
			<property name="SoundPickup" value="trapwood_grab" />
			<property name="SoundPlace" value="trapwood_place" />
			<property name="CanPickup" value="true" param1="rakeTrap" />
			<property name="TakeDelay" value="1" />
			<property name="TriggerSound" value="trap3x3WoodTrigger" />
			<property name="Damage" value="4" />
			<property name="DamageType" value="Bashing" />
			<property name="KnockdownChance" value="0.9" />
			<property name="BrushOffChance" value="0.12" />
			<property name="RearmSeconds" value="4" />
			<property name="AnimationTrigger" value="Spring" />
			<property class="RepairItems">
				<property name="resourceWood" value="10" />
				<property name="resourceForgedIron" value="1" />
			</property>
			<drop event="Destroy" name="resourceWood" count="4,10" />
			<drop event="Destroy" name="resourceScrapIron" count="1,3" />
			<drop event="Fall" count="0" />
			<property name="SortOrder1" value="B750" />
			<property name="SortOrder2" value="0010" />
			<property name="Group" value="Building" />
			<property name="BlockTag" value="Spike" />
			<property name="FilterTags" value="MC_building,SC_traps" />
		</block>
